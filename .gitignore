```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
.coverage

# MyPy cache
.mypy_cache/

# PyTest cache
.pytest_cache/

# Build directories
build/
dist/
target/

# Gradle
.gradle/

# System files
.DS_Store
Thumbs.db
```